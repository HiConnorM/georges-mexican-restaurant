{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(checkout|paypal-checkout|order-confirmation|search|401|detail_blog-posts|detail_category|detail_instagram|detail_posts-categories|detail_product|detail_sku)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    },
    {
      "source": "/templates/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ]
}
